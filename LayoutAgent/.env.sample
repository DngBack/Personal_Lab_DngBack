# Copy to .env and fill in your values.
#
# Model roles:
#   Chandra OCR-2  — layout extraction from image → <div data-bbox data-label>
#   Qwen 3 VL 4B  — schema alignment → <div data-schema> (maps layout to schema fields)
#   GPT-4o         — visual evaluation + prompt optimization (always via OpenAI)

# ============================================================
# 1. OPENAI — required for evaluation (GPT-4o) + prompt optimizer
# ============================================================
OPENAI_API_KEY=sk-...

# Optional: route all OpenAI calls through a proxy
# OPENAI_BASE_URL=https://your-proxy/v1

# ============================================================
# 2. QWEN 3 VL 4B — schema alignment model
#    Serve locally: vllm serve Qwen/Qwen3-VL-4B-Instruct --port 8000
# ============================================================
QWEN_BASE_URL=http://localhost:8000/v1
QWEN_API_KEY=EMPTY
QWEN_MODEL=Qwen/Qwen3-VL-4B-Instruct

# ============================================================
# 3. CHANDRA OCR-2 — layout extraction
#    Option A: datalab cloud API
#      CHANDRA_BASE_URL=https://api.datalab.to/api/v1
#      CHANDRA_API_KEY=your-datalab-key
#    Option B: local GPU via layoutDectectionChan/run_pdf_llm_log.py
#      (no env vars needed, call directly)
# ============================================================
CHANDRA_BASE_URL=https://api.datalab.to/api/v1
CHANDRA_API_KEY=your-datalab-key
CHANDRA_MODEL=datalab-to/chandra-ocr-2

# ============================================================
# 4. LOCAL MODE — run Chandra + Qwen via HuggingFace Transformers
#    (no API needed; requires CUDA + model weights downloaded)
# ============================================================
# USE_LOCAL_MODELS=1          # enable local mode for both models
# CHANDRA_DEVICE=cuda:0       # GPU for Chandra OCR-2
# QWEN_DEVICE=cuda:0          # GPU for Qwen 3 VL 4B (can be different GPU)

# ============================================================
# Optional model overrides (rarely needed)
# ============================================================
# ALIGN_MODEL=Qwen/Qwen3-VL-4B-Instruct   # overrides QWEN_MODEL for schema alignment
# JUDGE_MODEL=gpt-4o                        # model for visual evaluation (always OpenAI)
# OPTIMIZER_MODEL=gpt-4o                    # model for prompt optimization (always OpenAI)
